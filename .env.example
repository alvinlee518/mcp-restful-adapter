# MCP RESTful Adapter - Environment Configuration
# Copy this file to .env and fill in your values.

# ── Service A ───────────────────────────────────────────────────
SERVICE_A_SPEC_URL=https://your-api-a.example.com/v2/api-docs
SERVICE_A_BASE_URL=https://your-api-a.example.com
SERVICE_A_METHODS=GET,POST
SERVICE_A_EXCLUDE=(?i)(save|delete|remove|create|update)

# ── Service B ───────────────────────────────────────────────────
SERVICE_B_SPEC_URL=https://your-api-b.example.com/v2/api-docs
SERVICE_B_BASE_URL=https://your-api-b.example.com
SERVICE_B_METHODS=GET,POST
SERVICE_B_EXCLUDE=(?i)(save|delete|remove|create|update)
